@model NovaStore.ViewModels.Cart.CartViewModel

@{
    ViewData["Title"] = "Your Bag";
}

<div class="cart-page">
    <h1>Your Bag <span style="font-size:22px;color:var(--gray-400);font-weight:300">(@Model.ItemCount items)</span></h1>

    @if (!Model.Items.Any())
    {
        <div style="padding:60px 0;text-align:center">
            <p style="color:var(--gray-600);margin-bottom:24px">Your bag is empty.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-dark">Continue Shopping</a>
        </div>
    }
    else
    {
        <div class="cart-layout">

            <div class="cart-items">

                <div class="cart-header">
                    <span>Product</span>
                    <span>Price</span>
                    <span>Quantity</span>
                    <span>Total</span>
                    <span></span>
                </div>

                @foreach (var item in Model.Items)
                {
                    <div class="cart-item">
                        <div class="cart-item-info">
                            <div class="cart-item-img">
                                <img src="~/images/products/@item.ImageFileName" alt="@item.ProductName">
                            </div>
                            <div>
                                <p class="cart-item-name">@item.ProductName</p>
                                <p class="cart-item-variant">@item.VariantLabel</p>
                            </div>
                        </div>
                        <div class="cart-item-price">$@item.UnitPrice</div>

                        <form asp-controller="Cart" asp-action="UpdateQty" method="post" class="qty-control" style="width:fit-content">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <button type="submit" name="quantity" value="@(item.Quantity - 1)" class="qty-btn" style="width:38px;height:44px">−</button>
                            <input type="number" class="qty-input" value="@item.Quantity" min="1" max="@item.AvailableStock" style="width:46px;height:44px" disabled>
                            <button type="submit" name="quantity" value="@(item.Quantity + 1)" class="qty-btn" style="width:38px;height:44px">+</button>
                        </form>

                        <div class="cart-item-price">$@item.LineTotal</div>

                        <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                            <button type="submit" class="cart-remove" title="Remove"><i class="fa fa-xmark"></i></button>
                        </form>
                    </div>
                }

                <div style="margin-top:32px">
                    <a asp-controller="Shop" asp-action="Index" style="display:inline-flex;align-items:center;gap:10px;font-size:11px;letter-spacing:2.5px;text-transform:uppercase;font-weight:600;color:var(--black)">
                        <i class="fa fa-arrow-left"></i> Continue Shopping
                    </a>
                </div>
            </div>

            <aside>
                <div class="order-summary">
                    <h3>Order Summary</h3>

                    <div class="summary-row">
                        <span>Subtotal (@Model.ItemCount items)</span>
                        <span>$@Model.Subtotal.ToString("0.00")</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span style="color:var(--camel);font-weight:500">Free</span>
                    </div>
                    <div class="summary-row">
                        <span>Estimated Tax</span>
                        <span>$@Model.Tax.ToString("0.00")</span>
                    </div>

                    @if (Model.CouponApplied)
                    {
                        <div class="summary-row" style="color:var(--camel)">
                            <span>Discount (@Model.CouponCode)</span>
                            <span>−$@Model.Discount.ToString("0.00")</span>
                        </div>
                    }

                    <form asp-controller="Cart" asp-action="ApplyCoupon" method="post" class="coupon-row">
                        @Html.AntiForgeryToken()
                        <input type="text" name="couponCode" placeholder="Coupon code">
                        <button type="submit">Apply</button>
                    </form>
                    @if (TempData["CouponMessage"] != null)
                    {
                        <p style="font-size:11px;margin-top:-16px;margin-bottom:16px;min-height:16px;color:@(Model.CouponApplied ? "var(--camel)" : "#c0392b")">
                            @TempData["CouponMessage"]
                        </p>
                    }

                    <div class="summary-row total">
                        <span>Total</span>
                        <span>$@Model.Total.ToString("0.00")</span>
                    </div>

                    <a asp-controller="Checkout" asp-action="Index" class="checkout-btn" style="display:block;text-align:center;text-decoration:none">
                        Proceed to Checkout &nbsp;<i class="fa fa-arrow-right"></i>
                    </a>
                </div>
            </aside>

        </div>
    }
</div>
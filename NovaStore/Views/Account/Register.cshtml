@model NovaStore.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div style="max-width:420px;margin:80px auto;padding:0 20px">
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:36px;text-align:center;margin-bottom:8px">Create Account</h1>
    <p style="text-align:center;color:var(--gray-600);margin-bottom:32px">Join the NOVA circle</p>

    <div asp-validation-summary="ModelOnly" style="color:#c0392b;font-size:13px;margin-bottom:16px"></div>

    <form asp-controller="Account" asp-action="Register" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label>Full Name</label>
            <input asp-for="FullName" />
            <span asp-validation-for="FullName" style="color:#c0392b;font-size:12px"></span>
        </div>

        <div class="form-group">
            <label>Email</label>
            <input asp-for="Email" type="email" />
            <span asp-validation-for="Email" style="color:#c0392b;font-size:12px"></span>
        </div>

        <div class="form-group">
            <label>Phone</label>
            <input asp-for="Phone" />
            <span asp-validation-for="Phone" style="color:#c0392b;font-size:12px"></span>
        </div>

        <div class="form-group">
            <label>Password</label>
            <input asp-for="Password" type="password" />
            <span asp-validation-for="Password" style="color:#c0392b;font-size:12px"></span>
        </div>

        <div class="form-group">
            <label>Confirm Password</label>
            <input asp-for="ConfirmPassword" type="password" />
            <span asp-validation-for="ConfirmPassword" style="color:#c0392b;font-size:12px"></span>
        </div>

        <button type="submit" class="form-submit" style="width:100%">Create Account</button>

        <p style="text-align:center;margin-top:24px;font-size:13px;color:var(--gray-600)">
            Already have an account? <a asp-controller="Account" asp-action="Login" style="color:var(--camel)">Sign in</a>
        </p>
    </form>
</div>
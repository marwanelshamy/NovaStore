@model NovaStore.ViewModels.Admin.AdminCouponFormViewModel

@{
    ViewData["Title"] = "Add Coupon";
    Layout = "_AdminLayout";
}

<div class="admin-topbar">
    <h1>Add Coupon</h1>
</div>

<div class="admin-card" style="max-width:480px">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <label>Coupon Code</label>
        <input asp-for="Code" placeholder="e.g. NOVA10" style="text-transform:uppercase" />
        <span asp-validation-for="Code" style="color:#c0392b;font-size:12px"></span>

        <label>Discount Percent</label>
        <input asp-for="DiscountPercent" type="number" step="0.01" placeholder="e.g. 10" />
        <span asp-validation-for="DiscountPercent" style="color:#c0392b;font-size:12px"></span>

        <label>Expiry Date (optional)</label>
        <input asp-for="ExpiryDate" type="date" />

        <label>Usage Limit (optional, leave blank for unlimited)</label>
        <input asp-for="UsageLimit" type="number" />

        <button type="submit" class="btn-admin" style="margin-top:8px">Create Coupon</button>
    </form>
</div>
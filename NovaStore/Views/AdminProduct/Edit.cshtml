@model NovaStore.ViewModels.Admin.AdminProductFormViewModel

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_AdminLayout";
}

<div class="admin-topbar">
    <h1>Edit Product</h1>
</div>

<div class="admin-card">
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <label>Name</label>
        <input asp-for="Name" />

        <label>Slug (URL-friendly, e.g. sand-dune-maxi-dress)</label>
        <input asp-for="Slug" />

        <label>Description</label>
        <textarea asp-for="Description" rows="4"></textarea>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div>
                <label>Price</label>
                <input asp-for="Price" type="number" step="0.01" />
            </div>
            <div>
                <label>Old Price (optional, for sale items)</label>
                <input asp-for="OldPrice" type="number" step="0.01" />
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div>
                <label>Category</label>
                <select asp-for="CategoryId">
                    @foreach (var c in Model.CategoryOptions)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.CategoryId)">@c.Name</option>
                    }
                </select>
            </div>
            <div>
                <label>Collection (optional)</label>
                <select asp-for="CollectionId">
                    <option value="">-- None --</option>
                    @foreach (var c in Model.CollectionOptions)
                    {
                        <option value="@c.Id" selected="@(c.Id == Model.CollectionId)">@c.Name</option>
                    }
                </select>
            </div>
        </div>

        <div style="display:flex;gap:20px;margin-bottom:16px">
            <label style="display:flex;align-items:center;gap:8px;margin:0">
                <input asp-for="IsFeatured" type="checkbox" style="width:auto;margin:0" /> Featured
            </label>
            <label style="display:flex;align-items:center;gap:8px;margin:0">
                <input asp-for="IsActive" type="checkbox" style="width:auto;margin:0" /> Active
            </label>
        </div>

        @if (Model.ExistingImages.Any())
        {
            <label>Current Images</label>
            <div style="display:flex;gap:12px;margin-bottom:16px;flex-wrap:wrap">
                @foreach (var img in Model.ExistingImages)
                {
                    <div style="position:relative">
                        <img src="~/images/products/@img.FileName" style="width:80px;height:80px;object-fit:cover;border-radius:4px" />
                        <button type="button" onclick="deleteImage(@img.Id, this)"
                                style="position:absolute;top:-6px;right:-6px;width:20px;height:20px;border-radius:50%;background:#c0392b;color:white;border:none;cursor:pointer;font-size:11px">
                            ×
                        </button>
                    </div>
                }
            </div>
        }

        <label>Add More Images</label>
        <input type="file" name="NewImages" multiple accept=".jpg,.jpeg,.png,.webp" />

        <h3 style="margin:24px 0 12px;font-size:15px">Variants (Size / Color / Stock)</h3>
        <div id="variantsContainer">
            @{
                var variantRows = Model.Variants.Count > 0 ? Model.Variants.Count : 3;
            }
            @for (int i = 0; i < variantRows; i++)
            {
                var v = i < Model.Variants.Count ? Model.Variants[i] : null;
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;margin-bottom:10px">
                    <input name="Variants[@i].Size" placeholder="Size (e.g. M)" value="@v?.Size" />
                    <input name="Variants[@i].Color" placeholder="Color (e.g. Sand)" value="@v?.Color" />
                    <input name="Variants[@i].SKU" placeholder="SKU" value="@v?.SKU" />
                    <input name="Variants[@i].StockQuantity" type="number" placeholder="Stock" value="@v?.StockQuantity" />
                </div>
            }
        </div>

        <button type="submit" class="btn-admin" style="margin-top:16px">Save Changes</button>
    </form>
</div>

@section Scripts {
    <script>
        async function deleteImage(imageId, btn) {
            if (!confirm('Remove this image?')) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const res = await fetch('/AdminProduct/DeleteImage', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `imageId=${imageId}&__RequestVerificationToken=${encodeURIComponent(token)}`
            });

            if (res.ok) {
                btn.closest('div').remove();
            }
        }
    </script>
}
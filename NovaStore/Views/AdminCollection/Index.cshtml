@{
    ViewData["Title"] = "Collections";
    Layout = "_AdminLayout";
}

<div class="admin-topbar">
    <h1>Collections</h1>
    <a asp-action="Create" class="btn-admin">+ Add Collection</a>
</div>

@if (TempData["Error"] != null)
{
    <div style="background:#fbe9e9;color:#c0392b;padding:14px 18px;border-radius:8px;margin-bottom:20px;font-size:13px">
        @TempData["Error"]
    </div>
}

<div class="admin-card">
    <table class="admin-table">
        <tr>
            <th>Name</th>
            <th>Season</th>
            <th>Year</th>
            <th>Products</th>
            <th>Status</th>
            <th></th>
        </tr>
        @foreach (var c in Model)
        {
            <tr>
                <td><strong>@c.Name</strong></td>
                <td>@c.Season</td>
                <td>@c.Year</td>
                <td>@c.ProductCount</td>
                <td>
                    @if (c.IsCurrent)
                    {
                        <span style="background:#e6f4ea;color:#1e7e34;padding:3px 10px;border-radius:4px;font-size:12px;font-weight:600">Current</span>
                    }
                    else if (c.IsActive)
                    {
                        <span style="background:#f0f0f0;color:#666;padding:3px 10px;border-radius:4px;font-size:12px;font-weight:600">Active</span>
                    }
                    else
                    {
                        <span style="background:#fbe9e9;color:#c0392b;padding:3px 10px;border-radius:4px;font-size:12px;font-weight:600">Inactive</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn-admin btn-admin-outline">Edit</a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-admin btn-admin-danger" onclick="return confirm('Delete this collection?')">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </table>
</div>
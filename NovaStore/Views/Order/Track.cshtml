@model NovaStore.ViewModels.Order.OrderTrackingViewModel

@{
    ViewData["Title"] = "Track Order";
    var stages = new[] {
        NovaStore.Models.Enums.OrderStatus.Pending,
        NovaStore.Models.Enums.OrderStatus.Confirmed,
        NovaStore.Models.Enums.OrderStatus.Packed,
        NovaStore.Models.Enums.OrderStatus.Shipped,
        NovaStore.Models.Enums.OrderStatus.Delivered
    };
    var currentIdx = Array.IndexOf(stages, Model.CurrentStatus);
}

<div style="max-width:700px;margin:60px auto;padding:0 20px">

    <a asp-action="MyOrders" style="font-size:12px;color:var(--gray-600);text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-bottom:24px">
        <i class="fa fa-arrow-left"></i> Back to My Orders
    </a>

    <h1 style="font-family:'Cormorant Garamond',serif;font-size:32px;margin-bottom:8px">Order #@Model.OrderNumber</h1>
    <p style="color:var(--gray-600);margin-bottom:32px">Placed on @Model.CreatedAt.ToString("MMMM d, yyyy")</p>

    @if (Model.CurrentStatus == NovaStore.Models.Enums.OrderStatus.Cancelled)
    {
        <div style="background:#fbe9e9;color:#c0392b;padding:16px 20px;border-radius:8px;margin-bottom:32px">
            <i class="fa fa-circle-xmark"></i> This order was cancelled.
        </div>
    }
    else
    {
        <div style="display:flex;align-items:flex-start;margin-bottom:40px">
            @for (int i = 0; i < stages.Length; i++)
            {
                var isDone = i < currentIdx;
                var isCurrent = i == currentIdx;
                <div style="flex:1;text-align:center">
                    <div style="width:32px;height:32px;border-radius:50%;margin:0 auto 8px;display:flex;align-items:center;justify-content:center;font-size:13px;
                        background:@(isDone ? "#e6f4ea" : isCurrent ? "#1a1a1a" : "#f0f0f0");
                        color:@(isDone ? "#1e7e34" : isCurrent ? "white" : "#999")">
                        @(isDone ? "✓" : (i + 1).ToString())
                    </div>
                    <p style="font-size:12px;margin:0;color:@(isCurrent || isDone ? "#1a1a1a" : "#999");font-weight:@(isCurrent ? "600" : "400")">@stages[i]</p>
                </div>
                @if (i < stages.Length - 1)
                {
                    <div style="height:2px;flex:0 0 30px;margin-top:16px;background:@(i < currentIdx ? "#e6f4ea" : "#e0e0e0")"></div>
                }
            }
        </div>
    }

    <div style="background:white;border:1px solid #eee;border-radius:8px;padding:24px;margin-bottom:24px">
        <h3 style="font-size:15px;margin-bottom:16px">Items</h3>
        @foreach (var item in Model.Items)
        {
            <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f5f5f5;font-size:13px">
                <span>@item.ProductName (@item.VariantLabel) x@(item.Quantity)</span>
                <span>$@item.LineTotal.ToString("0.00")</span>
            </div>
        }
        <div style="display:flex;justify-content:space-between;padding-top:12px;font-weight:600">
            <span>Total</span>
            <span>$@Model.Total.ToString("0.00")</span>
        </div>
    </div>

    <div style="background:white;border:1px solid #eee;border-radius:8px;padding:24px">
        <h3 style="font-size:15px;margin-bottom:16px">History</h3>
        @foreach (var h in Model.Timeline)
        {
            <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;color:var(--gray-600)">
                <span>@h.Status @(h.Note != null ? $"— {h.Note}" : "")</span>
                <span>@h.ChangedAt.ToString("MMM d, h:mm tt")</span>
            </div>
        }
    </div>

</div>
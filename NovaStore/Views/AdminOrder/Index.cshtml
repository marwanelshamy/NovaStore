@model NovaStore.ViewModels.Admin.AdminOrderListViewModel

@{
    ViewData["Title"] = "Orders";
    Layout = "_AdminLayout";
}

<div class="admin-topbar">
    <h1>Orders</h1>
</div>

<div style="margin-bottom:20px;display:flex;gap:6px;flex-wrap:wrap">
    <a asp-action="Index" class="filter-btn @(Model.StatusFilter == null ? "filter-active" : "")">All</a>
    @foreach (var s in Enum.GetValues<NovaStore.Models.Enums.OrderStatus>())
    {
        var isCancelled = s == NovaStore.Models.Enums.OrderStatus.Cancelled;
        <a asp-action="Index" asp-route-status="@s"
           class="filter-btn @(Model.StatusFilter == s.ToString() ? "filter-active" : "")"
           style="@(isCancelled ? "color:#c0392b" : "")">@s</a>
    }
</div>

<div style="background:white;border-radius:8px;border:1px solid #eee;overflow:hidden">
    <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
            <tr style="background:#fafafa">
                <th style="text-align:left;padding:10px 16px;font-weight:500;color:#888;font-size:12px;text-transform:uppercase;letter-spacing:0.5px">Order</th>
                <th style="text-align:left;padding:10px 16px;font-weight:500;color:#888;font-size:12px;text-transform:uppercase;letter-spacing:0.5px">Customer</th>
                <th style="text-align:left;padding:10px 16px;font-weight:500;color:#888;font-size:12px;text-transform:uppercase;letter-spacing:0.5px">Payment</th>
                <th style="text-align:left;padding:10px 16px;font-weight:500;color:#888;font-size:12px;text-transform:uppercase;letter-spacing:0.5px">Status</th>
                <th style="text-align:right;padding:10px 16px;font-weight:500;color:#888;font-size:12px;text-transform:uppercase;letter-spacing:0.5px">Total</th>
                <th style="padding:10px 16px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model.Orders)
            {
                var (bg, fg) = o.Status switch
                {
                    NovaStore.Models.Enums.OrderStatus.Pending => ("#f0f0f0", "#666"),
                    NovaStore.Models.Enums.OrderStatus.Confirmed => ("#e6f4ea", "#1e7e34"),
                    NovaStore.Models.Enums.OrderStatus.Packed => ("#e6f0fb", "#1a5fa8"),
                    NovaStore.Models.Enums.OrderStatus.Shipped => ("#e6f0fb", "#1a5fa8"),
                    NovaStore.Models.Enums.OrderStatus.Delivered => ("#e6f4ea", "#1e7e34"),
                    NovaStore.Models.Enums.OrderStatus.Cancelled => ("#fbe9e9", "#c0392b"),
                    _ => ("#f0f0f0", "#666")
                };
                <tr style="border-top:1px solid #f0f0f0">
                    <td style="padding:12px 16px">
                        <div style="font-weight:600;color:#1a1a1a">@o.OrderNumber</div>
                        <div style="font-size:12px;color:#aaa">@o.CreatedAt.ToString("MMM d, yyyy")</div>
                    </td>
                    <td style="padding:12px 16px;color:#555">@o.ShippingName</td>
                    <td style="padding:12px 16px;color:#555">@o.PaymentMethod</td>
                    <td style="padding:12px 16px">
                        <span style="display:inline-block;padding:3px 10px;border-radius:4px;font-size:12px;font-weight:600;background:@bg;color:@fg">@o.Status</span>
                    </td>
                    <td style="padding:12px 16px;text-align:right;font-weight:600">$@o.Total.ToString("0.00")</td>
                    <td style="padding:12px 16px;text-align:right">
                        <a asp-action="Details" asp-route-id="@o.Id" class="btn-admin btn-admin-outline" style="font-size:12px">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
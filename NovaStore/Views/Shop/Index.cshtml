@model NovaStore.ViewModels.Shop.ProductListViewModel

@{
    ViewData["Title"] = "Shop";
}

<div class="shop-banner">
    <div class="shop-banner-content">
        <h1>All Collections</h1>
        <p>Home &nbsp;/&nbsp; Shop</p>
    </div>
</div>

<div class="shop-layout">

    <aside class="shop-sidebar">

        <div class="filter-section">
            <div class="filter-title">Category</div>
            <div class="filter-options">
                <a asp-action="Index" asp-route-categoryId="" asp-route-sortBy="@Model.Filters.SortBy"
                   class="filter-option" style="text-decoration:none;color:inherit">
                    All Items <span style="margin-left:auto;color:var(--gray-400)">@Model.TotalCount</span>
                </a>
                @foreach (var cat in Model.Filters.Categories)
                {
                    <a asp-action="Index" asp-route-categoryId="@cat.Id" asp-route-sortBy="@Model.Filters.SortBy"
                       class="filter-option @(Model.Filters.SelectedCategoryId == cat.Id ? "active" : "")"
                       style="text-decoration:none;color:inherit">
                        @cat.Name <span style="margin-left:auto;color:var(--gray-400)">@cat.ProductCount</span>
                    </a>
                }
            </div>
        </div>

        <div class="filter-section">
            <div class="filter-title">Collection</div>
            <div class="filter-options">
                @foreach (var col in Model.Filters.Collections)
                {
                    <a asp-action="Index" asp-route-collectionId="@col.Id" asp-route-sortBy="@Model.Filters.SortBy"
                       class="filter-option @(Model.Filters.SelectedCollectionId == col.Id ? "active" : "")"
                       style="text-decoration:none;color:inherit">
                        @col.Name
                    </a>
                }
            </div>
        </div>

    </aside>

    <main>
        <div class="shop-toolbar">
            <p class="results-count">Showing <strong>@Model.Products.Count</strong> of @Model.TotalCount items</p>
            <div class="toolbar-right">
                <select class="sort-select" onchange="changeSorting(this.value)">
                    <option value="featured" selected="@(Model.Filters.SortBy == "featured")">Featured</option>
                    <option value="newest" selected="@(Model.Filters.SortBy == "newest")">Newest First</option>
                    <option value="price_low" selected="@(Model.Filters.SortBy == "price_low")">Price: Low to High</option>
                    <option value="price_high" selected="@(Model.Filters.SortBy == "price_high")">Price: High to Low</option>
                </select>
            </div>
        </div>

        @if (!Model.Products.Any())
        {
            <p style="padding:60px 0;text-align:center;color:var(--gray-600)">No products found.</p>
        }
        else
        {
            <div class="shop-grid">
                @foreach (var product in Model.Products)
                {
                    <div>
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <div style="display:flex;justify-content:center;align-items:center;gap:8px;margin-top:60px">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index" asp-route-page="@i"
                           asp-route-categoryId="@Model.Filters.SelectedCategoryId"
                           asp-route-collectionId="@Model.Filters.SelectedCollectionId"
                           asp-route-sortBy="@Model.Filters.SortBy"
                           style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;
                            border:1px solid @(i == Model.CurrentPage ? "var(--black)" : "var(--gray-200)");
                            background:@(i == Model.CurrentPage ? "var(--black)" : "transparent");
                            color:@(i == Model.CurrentPage ? "white" : "inherit");
                            text-decoration:none;font-size:12px">
                            @i
                        </a>
                    }
                </div>
            }
        }

    </main>
</div>

@section Scripts {
    <script>
        function changeSorting(sortValue) {
            const url = new URL(window.location.href);
            url.searchParams.set('sortBy', sortValue);
            url.searchParams.set('page', '1');
            window.location.href = url.toString();
        }
    </script>
}
@model NovaStore.ViewModels.Checkout.OrderConfirmationViewModel

@{
    ViewData["Title"] = "Order Confirmed";
}

<div style="max-width:600px;margin:80px auto;text-align:center;padding:0 20px">
    <i class="fa fa-circle-check" style="font-size:48px;color:var(--camel);margin-bottom:24px"></i>
    <h1 style="font-family:'Cormorant Garamond',serif;font-size:36px;margin-bottom:16px">Thank You!</h1>
    <p style="color:var(--gray-600);margin-bottom:32px">Your order has been placed successfully.</p>

    <div style="border:1px solid var(--gray-200);padding:24px;text-align:left;margin-bottom:32px">
        <p><strong>Order Number:</strong> @Model.OrderNumber</p>
        <p><strong>Date:</strong> @Model.PlacedDate.ToString("MMMM d, yyyy")</p>
        <p><strong>Payment Method:</strong> @Model.PaymentMethod</p>
        <p><strong>Total:</strong> $@Model.Total.ToString("0.00")</p>
        <hr style="margin:16px 0;border-color:var(--gray-200)" />
        <p><strong>Shipping To:</strong></p>
        <p>@Model.ShippingName</p>
        <p>@Model.ShippingAddress</p>
        <p>@Model.ShippingCity, @Model.ShippingCountry</p>
    </div>

    <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Continue Shopping</a>
</div>
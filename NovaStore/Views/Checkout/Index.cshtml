@model NovaStore.ViewModels.Checkout.CheckoutViewModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="contact-page">
    <div class="contact-grid">

        <div class="contact-form" style="flex:1">
            <h3>Shipping Details</h3>

            <form asp-controller="Checkout" asp-action="PlaceOrder" method="post">
                @Html.AntiForgeryToken()

                <div class="form-row">
                    <div class="form-group">
                        <label>Full Name *</label>
                        <input asp-for="FullName" />
                        <span asp-validation-for="FullName" style="color:#c0392b;font-size:12px"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label>Email *</label>
                    <input asp-for="Email" type="email" />
                    <span asp-validation-for="Email" style="color:#c0392b;font-size:12px"></span>
                </div>

                <div class="form-group">
                    <label>Phone *</label>
                    <input asp-for="Phone" />
                    <span asp-validation-for="Phone" style="color:#c0392b;font-size:12px"></span>
                </div>

                <div class="form-group">
                    <label>Address *</label>
                    <input asp-for="Address" />
                    <span asp-validation-for="Address" style="color:#c0392b;font-size:12px"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>City *</label>
                        <input asp-for="City" />
                        <span asp-validation-for="City" style="color:#c0392b;font-size:12px"></span>
                    </div>
                    <div class="form-group">
                        <label>Country *</label>
                        <input asp-for="Country" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Order Notes (optional)</label>
                    <textarea asp-for="Notes"></textarea>
                </div>

                <div class="pd-divider"></div>

                <p style="font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#aaa;margin-bottom:6px">Step 2 of 3</p>
                <h2 style="font-family:'Cormorant Garamond',serif;font-weight:400;font-size:28px;margin-bottom:24px">How would you like to pay</h2>

                <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:24px" id="payCards">

                    <label class="pcard" style="position:relative;display:flex;align-items:center;gap:16px;padding:20px;border:0.5px solid #ddd;border-radius:12px;cursor:pointer">
                        <input type="radio" asp-for="PaymentMethod" value="COD" checked style="position:absolute;opacity:0" />
                        <div style="width:44px;height:44px;border-radius:50%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fa fa-truck" style="font-size:18px"></i>
                        </div>
                        <div style="flex:1">
                            <p style="font-weight:600;margin:0;font-size:15px">Cash on delivery</p>
                            <p style="font-size:13px;color:#888;margin:2px 0 0">Settle up when your order reaches you</p>
                        </div>
                        <div class="check" style="width:20px;height:20px;border-radius:50%;border:1.5px solid #ccc;flex-shrink:0"></div>
                    </label>

                    <label class="pcard" style="position:relative;display:flex;align-items:center;gap:16px;padding:20px;border:0.5px solid #ddd;border-radius:12px;cursor:pointer">
                        <input type="radio" asp-for="PaymentMethod" value="Card" style="position:absolute;opacity:0" />
                        <div style="width:44px;height:44px;border-radius:50%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fa fa-credit-card" style="font-size:18px"></i>
                        </div>
                        <div style="flex:1">
                            <p style="font-weight:600;margin:0;font-size:15px">Card</p>
                            <p style="font-size:13px;color:#888;margin:2px 0 0">Visa, Mastercard or Meeza, charged instantly</p>
                        </div>
                        <div style="display:flex;gap:8px;flex-shrink:0;align-items:center">
                            <img src="https://cdn.jsdelivr.net/npm/simple-icons@v9/icons/visa.svg" alt="Visa" style="height:18px;width:auto">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/2/2a/Mastercard-logo.svg" alt="Mastercard" style="height:24px;width:auto">
                            <img src="~/images/payment-icons/meeza.png" alt="Meeza" style="height:20px;width:auto">
                        </div>
                        <div class="check" style="width:20px;height:20px;border-radius:50%;border:1.5px solid #ccc;flex-shrink:0"></div>
                    </label>

                    <label class="pcard" style="position:relative;display:flex;align-items:center;gap:16px;padding:20px;border:0.5px solid #ddd;border-radius:12px;cursor:pointer">
                        <input type="radio" asp-for="PaymentMethod" value="Wallet" style="position:absolute;opacity:0" />
                        <div style="width:44px;height:44px;border-radius:50%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <i class="fa fa-wallet" style="font-size:18px"></i>
                        </div>
                        <div style="flex:1">
                            <p style="font-weight:600;margin:0;font-size:15px">Mobile wallet</p>
                            <p style="font-size:13px;color:#888;margin:2px 0 0">Vodafone Cash, Orange Money, Etisalat</p>
                        </div>
                        <div class="check" style="width:20px;height:20px;border-radius:50%;border:1.5px solid #ccc;flex-shrink:0"></div>
                    </label>
                    <label class="pcard" style="position:relative;display:flex;align-items:center;gap:16px;padding:20px;border:0.5px solid #ddd;border-radius:12px;cursor:pointer">
                        <input type="radio" asp-for="PaymentMethod" value="Wallet" style="position:absolute;opacity:0" />
                        <div style="width:44px;height:44px;border-radius:50%;background:#f5f5f5;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <img src="~/images/payment-icons/fawry.png" alt="Fawry" style="width:50px;height:auto">
                        </div>
                        <div style="flex:1">
                            <p style="font-weight:600;margin:0;font-size:15px">Fawry</p>
                            <p style="font-size:13px;color:#888;margin:2px 0 0">Get a reference code, pay at any kiosk</p>
                        </div>
                        <div class="check" style="width:20px;height:20px;border-radius:50%;border:1.5px solid #ccc;flex-shrink:0"></div>
                    </label>

                </div>

                <div style="margin-bottom:24px;padding:14px 16px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;gap:10px">
                    <i class="fa fa-shield-halved" style="font-size:16px;color:#888"></i>
                    <p style="font-size:12.5px;color:#888;margin:0">Encrypted end to end. NOVA never stores or sees your card number.</p>
                </div>

                <button type="submit" class="form-submit">Place Order &nbsp;<i class="fa fa-arrow-right"></i></button>
            </form>
        </div>

        <aside style="width:380px">
            <div class="order-summary">
                <h3>Order Summary</h3>
                @foreach (var item in Model.Cart!.Items)
                {
                    <div class="summary-row">
                        <span>@item.ProductName (@item.VariantLabel) x@(item.Quantity)</span>
                        <span>$@item.LineTotal.ToString("0.00")</span>
                    </div>
                }
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>$@Model.Cart.Subtotal.ToString("0.00")</span>
                </div>
                <div class="summary-row">
                    <span>Tax</span>
                    <span>$@Model.Cart.Tax.ToString("0.00")</span>
                </div>
                @if (Model.Cart.CouponApplied)
                {
                    <div class="summary-row" style="color:var(--camel)">
                        <span>Discount (@Model.Cart.CouponCode)</span>
                        <span>−$@Model.Cart.Discount.ToString("0.00")</span>
                    </div>
                }
                <div class="summary-row total">
                    <span>Total</span>
                    <span>$@Model.Cart.Total.ToString("0.00")</span>
                </div>
            </div>
        </aside>

    </div>
</div>

@section Scripts {
    <script>
        const payCards = document.querySelectorAll('.pcard');
        function renderPayCards() {
            payCards.forEach(c => {
                const input = c.querySelector('input');
                const check = c.querySelector('.check');
                if (input.checked) {
                    c.style.borderColor = '#1a1a1a';
                    c.style.borderWidth = '1.5px';
                    check.style.border = 'none';
                    check.style.background = '#1a1a1a';
                    check.innerHTML = '<i class="fa fa-check" style="font-size:10px;color:white;display:flex;align-items:center;justify-content:center;height:100%"></i>';
                } else {
                    c.style.borderColor = '#ddd';
                    c.style.borderWidth = '0.5px';
                    check.style.border = '1.5px solid #ccc';
                    check.style.background = 'transparent';
                    check.innerHTML = '';
                }
            });
        }
        payCards.forEach(c => c.addEventListener('click', () => {
            c.querySelector('input').checked = true;
            renderPayCards();
        }));
        renderPayCards();
    </script>
}
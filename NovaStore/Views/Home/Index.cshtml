@model IEnumerable<NovaStore.ViewModels.Shop.ProductCardViewModel>

@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<section class="hero">
    <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1509631179647-0177331693ae?w=900&q=80" alt="Summer Collection">
    </div>
    <div class="hero-text">
        <p class="hero-eyebrow">New Arrival — SS 2025</p>
        <h1 class="hero-title">Desert<br><em>Bloom</em><br>Collection</h1>
        <p class="hero-desc">Flowing silhouettes inspired by the warmth of sand dunes and the quiet elegance of the evening sky.</p>
        <div class="hero-actions">
            <a asp-controller="Shop" asp-action="Index" class="btn btn-dark">Shop Collection <i class="fa fa-arrow-right"></i></a>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-outline">Explore All</a>
        </div>
        <div class="hero-scroll">Scroll to Discover</div>
    </div>
</section>

<!-- Featured Products -->
<section class="featured">
    <div class="section-header">
        <div>
            <p class="section-label">Handpicked</p>
            <h2 class="section-title">Best <em>Sellers</em></h2>
        </div>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline">View All</a>
    </div>
    <div class="products-grid">
        @foreach (var product in Model)
        {
            <div class="product-card" onclick="location.href='/Product/Details/@product.Slug'">
                <div class="product-img">
                    <img src="~/images/products/@product.ImageFileName" alt="@product.Name">
                    @if (product.IsNew)
                    {
                        <span class="product-badge badge-new">New</span>
                    }
                    else if (product.IsOnSale)
                    {
                        <span class="product-badge badge-sale">Sale</span>
                    }
                    <div class="product-actions">
                        <button class="product-action-btn"><i class="fa fa-heart"></i></button>
                        <button class="product-action-btn"><i class="fa fa-eye"></i></button>
                        <button class="product-action-btn"><i class="fa fa-bag-shopping"></i></button>
                    </div>
                </div>
                <div class="product-info">
                    <p class="product-category">@product.CategoryName</p>
                    <h3 class="product-name">@product.Name</h3>
                    <div class="product-price">
                        @if (product.IsOnSale)
                        {
                            <span class="price price-sale">$@product.Price</span>
                            <span class="price-old">$@product.OldPrice</span>
                        }
                        else
                        {
                            <span class="price">$@product.Price</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</section>